# Ocean.io — get from: Ocean.io dashboard > API Settings
OCEAN_API_KEY=your_ocean_api_key_here

# Prospeo — get from: Prospeo dashboard > API
PROSPEO_API_KEY=your_prospeo_api_key_here

# Eazyreach — get from: Eazyreach dashboard (topped up by Subspace)
EAZYREACH_API_KEY=your_eazyreach_api_key_here

# Brevo — get from: Brevo > SMTP & API > API Keys
BREVO_API_KEY=your_brevo_api_key_here

# Must match a verified sender domain in your Brevo account
SENDER_EMAIL=you@yourdomain.com
SENDER_NAME=Your Name

# Optional tuning
OCEAN_MAX_RESULTS=10
PROSPEO_SENIORITY_FILTER=c_suite,vp
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=2.0

# Optional: comma-separated domains to exclude from lookalike results
EXCLUDE_DOMAINS=
